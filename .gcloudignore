# What NOT to upload to Cloud Build on `gcloud run deploy --source .`
# (Secrets are mounted from Secret Manager at deploy time — never from source.)

# Secrets / local env
.env
.env.*
*cookies.txt
*.cookies
*.pem
*.key
service-account*.json
gcp-key*.json
secrets/

# Version control + deps + build output (rebuilt inside the container)
.git/
.gitignore
node_modules/
.next/
out/
*.tsbuildinfo

# Docs / local-only assets (not needed at runtime)
*.md
COST_AUDIT.md
.vscode/
.idea/
.DS_Store
*.log
/tmp
*.mp3
*.wav
*.mov
*.mp4
