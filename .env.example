# ─────────────────────────────────────────────────────────────────────────────
# CounterPoints — environment template
# Copy to `.env.local` and fill in. NEVER commit `.env.local` (it's gitignored).
# In production these are mounted from Google Secret Manager (see deploy.sh).
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED: AI / LLM ───────────────────────────────────────────────────────
# Gemini (claim detection, verdicts, quotes, vision, search grounding).
# Get a key: https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=

# Groq — Whisper speech-to-text for live tab/mic capture.
# Get a key: https://console.groq.com/keys
GROQ_API_KEY=

# xAI Grok — X / Community Notes search per claim.
# Get a key: https://console.x.ai
XAI_API_KEY=

# ── REQUIRED: Search / sources ───────────────────────────────────────────────
# Tavily — primary web search for Left/Center/Right/Alt article sources.
# Get keys: https://app.tavily.com  (1,000 free credits/mo). 2 & 3 are optional
# extra keys the app rotates through when the first is rate-limited/out of credits.
TAVILY_API_KEY=
TAVILY_API_KEY_2=
TAVILY_API_KEY_3=

# Jina — search + page-read fallback when Tavily/Gemini miss.
# Get a key: https://jina.ai/reader (free tier)
JINA_API_KEY=

# YouTube Data API v3 — video title/channel/duration metadata (free quota).
# Enable + key: https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=

# ── REQUIRED: Google Cloud (Firestore + Storage + Vertex) ────────────────────
# Used for: session history, transcript cache, knowledge base, embeddings.
# Locally, auth with `gcloud auth application-default login` (ADC).
GCLOUD_PROJECT=your-gcp-project-id
GCS_BUCKET=your-bucket.appspot.com

# ── OPTIONAL but recommended: reliable captions ──────────────────────────────
# Residential proxy so yt-dlp can fetch captions (YouTube blocks datacenter IPs).
# Format: http://USER:PASS@host:port  — e.g. Webshare Rotating Residential.
# Without this, caption-less videos fall back to slower AI transcription.
PROXY_URL=

# Path to an exported YouTube cookies.txt (Netscape format) for yt-dlp.
# See the README "YouTube cookies" section for how to export it.
YTDLP_COOKIES=./www.youtube.com_cookies.txt

# ── OPTIONAL ─────────────────────────────────────────────────────────────────
# Protects server-to-server admin endpoints. Set to any long random string.
ADMIN_SECRET=
